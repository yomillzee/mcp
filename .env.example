# Required for Custom GPT / public callers: set in Railway Variables
# If unset, /google-ads/* routes stay open (local dev only — set this in production).
API_KEY=

# Preferred names (Railway)
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=

# LinkedIn Marketing API (same names as linkedin-ads-dashboard)
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REFRESH_TOKEN=
# API version header (Linkedin-Version). Use 202509 for adCampaignGroups; 202404 often 404s.
LINKEDIN_VERSION=202509

# Meta Marketing API (Business Manager — lists all client ad accounts)
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=
META_BUSINESS_ID=1064007753695517
META_API_VERSION=v21.0

# Also accepted (same as linkedin-ads-dashboard .env)
# GOOGLE_DEVELOPER_TOKEN=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REFRESH_TOKEN=
# GOOGLE_LOGIN_CUSTOMER_ID=

# GA4 BigQuery access (single-env-var credentials pattern)
# Railway: do NOT paste multiline JSON in the web UI (often truncates). Use base64
# of the whole key file (one line, no leading "{") OR minify to one line, OR
# `railway variables --set "GCP_SERVICE_ACCOUNT_JSON=$(cat key.json)"`.
GCP_SERVICE_ACCOUNT_JSON=
BQ_PROJECT_ID=
BQ_DATASET_ID=
# Optional: GA4 property id for warehouse account_id (defaults to BQ_DATASET_ID)
# GA4_PROPERTY_ID=

# Multi-client GA4 (different GCP projects). One-line JSON in Railway:
# GA4_CLIENTS={"penn":{"label":"Penn Community Bank","bq_project_id":"penn-community-b-1699391543298","bq_dataset_id":"analytics_313855909"},"sagefrog":{"label":"Sagefrog","bq_project_id":"sagefrog","bq_dataset_id":"analytics_REPLACE_ME"},"synergistix":{"label":"Synergistix","bq_project_id":"synergistix-497616","bq_dataset_id":"analytics_REPLACE_ME"}}
# GA4_CLIENTS=

# --- BigQuery warehouse v2 (this repo) ---
# BQ_WAREHOUSE_PROJECT=penn-community-b-1699391543298
# BQ_DATASET_GOOGLE=warehouse_google_ads
# BQ_DATASET_META=warehouse_meta
# BQ_DATASET_LINKEDIN=warehouse_linkedin
# CRON_SECRET=
# SYNC_DATE_RANGE=LAST_7_DAYS
# SYNC_CLIENTS={"penn":{"label":"Penn Community Bank","bq_project_id":"penn-community-b-1699391543298","google_ads_customer_id":"","linkedin_account_id":"","meta_account_id":""}}
