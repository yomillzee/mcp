  "components": {
    "schemas": {
      "AccountRef": {
        "properties": {
          "customer_id": {
            "type": "string",
            "title": "Customer Id"
          },
          "resource_name": {
            "type": "string",
            "title": "Resource Name"
          },
          "descriptive_name": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Descriptive Name"
          },
          "currency_code": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Currency Code"
          },
          "time_zone": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Time Zone"
          },
          "status": {
            "type": "string",
            "title": "Status",
            "default": "ok"
          },
          "error": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Error"
          }
        },
        "type": "object",
        "required": [
          "customer_id",
          "resource_name"
        ],
        "title": "AccountRef"
      },
      "AccountsResponse": {
        "properties": {
          "count": {
            "type": "integer",
            "title": "Count"
          },
          "accounts": {
            "items": {
              "$ref": "#/components/schemas/AccountRef"
            },
            "type": "array",
            "title": "Accounts"
          }
        },
        "type": "object",
        "required": [
          "count",
          "accounts"
        ],
        "title": "AccountsResponse"
      },
      "CacheHealthResponse": {
        "properties": {
          "has_database_url": {
            "type": "boolean",
            "title": "Has Database Url"
          },
          "schema_ready": {
            "type": "boolean",
            "title": "Schema Ready"
          },
          "table_exists": {
            "type": "boolean",
            "title": "Table Exists"
          },
          "cache_rows": {
            "type": "integer",
            "title": "Cache Rows",
            "default": 0
          },
          "error": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Error"
          }
        },
        "type": "object",
        "required": [
          "has_database_url",
          "schema_ready",
          "table_exists"
        ],
        "title": "CacheHealthResponse"
      },
      "CredsFingerprintResponse": {
        "properties": {
          "client_id": {
            "anyOf": [
              {
                "additionalProperties": true,
                "type": "object",
                "properties": {}
              },
              {
                "type": "null"
              }
            ],
            "title": "Client Id"
          },
          "client_id_looks_valid": {
            "type": "boolean",
            "title": "Client Id Looks Valid",
            "default": false
          },
          "client_secret": {
            "anyOf": [
              {
                "additionalProperties": true,
                "type": "object",
                "properties": {}
              },
              {
                "type": "null"
              }
            ],
            "title": "Client Secret"
          },
          "refresh_token": {
            "anyOf": [
              {
                "additionalProperties": true,
                "type": "object",
                "properties": {}
              },
              {
                "type": "null"
              }
            ],
            "title": "Refresh Token"
          },
          "refresh_token_looks_valid": {
            "type": "boolean",
            "title": "Refresh Token Looks Valid",
            "default": false
          }
        },
        "type": "object",
        "title": "CredsFingerprintResponse"
      },
      "Ga4EnvSummary": {
        "properties": {
          "has_gcp_service_account_json": {
            "type": "boolean",
            "title": "Has Gcp Service Account Json"
          },
          "has_bq_project_id": {
            "type": "boolean",
            "title": "Has Bq Project Id"
          },
          "has_bq_dataset_id": {
            "type": "boolean",
            "title": "Has Bq Dataset Id"
          },
          "bq_project_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Bq Project Id"
          },
          "bq_dataset_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Bq Dataset Id"
          },
          "gcp_service_account_json_char_count": {
            "type": "integer",
            "title": "Gcp Service Account Json Char Count",
            "default": 0
          },
          "gcp_service_account_json_hint": {
            "type": "string",
            "title": "Gcp Service Account Json Hint",
            "description": "empty | raw_json | possibly_double_quoted_wrap | base64_or_other",
            "default": "empty"
          },
          "gcp_service_account_json_suspected_truncated": {
            "type": "boolean",
            "title": "Gcp Service Account Json Suspected Truncated",
            "description": "True if value is very short \u2014 common when Railway truncates a multiline paste.",
            "default": false
          },
          "gcp_service_account_json_parse_ok": {
            "type": "boolean",
            "title": "Gcp Service Account Json Parse Ok",
            "default": false
          },
          "gcp_service_account_json_parse_error": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Gcp Service Account Json Parse Error",
            "description": "Parse error detail when parse_ok is false (no secret material)."
          }
        },
        "type": "object",
        "required": [
          "has_gcp_service_account_json",
          "has_bq_project_id",
          "has_bq_dataset_id"
        ],
        "title": "Ga4EnvSummary"
      },
      "Ga4QueryRequest": {
        "properties": {
          "sql": {
            "type": "string",
            "title": "Sql",
            "description": "BigQuery SQL query"
          },
          "max_rows": {
            "type": "integer",
            "maximum": 50000.0,
            "minimum": 1.0,
            "title": "Max Rows",
            "description": "Maximum rows to return",
            "default": 1000
          }
        },
        "type": "object",
        "required": [
          "sql"
        ],
        "title": "Ga4QueryRequest"
      },
      "Ga4QueryResponse": {
        "properties": {
          "row_count": {
            "type": "integer",
            "title": "Row Count"
          },
          "rows": {
            "items": {
              "additionalProperties": true,
              "type": "object",
              "properties": {}
            },
            "type": "array",
            "title": "Rows"
          }
        },
        "type": "object",
        "required": [
          "row_count",
          "rows"
        ],
        "title": "Ga4QueryResponse"
      },
      "GoogleAdsEnvSummary": {
        "properties": {
          "has_developer_token": {
            "type": "boolean",
            "title": "Has Developer Token"
          },
          "has_login_customer_id": {
            "type": "boolean",
            "title": "Has Login Customer Id"
          },
          "has_client_id": {
            "type": "boolean",
            "title": "Has Client Id"
          },
          "has_client_secret": {
            "type": "boolean",
            "title": "Has Client Secret"
          },
          "has_refresh_token": {
            "type": "boolean",
            "title": "Has Refresh Token"
          }
        },
        "type": "object",
        "required": [
          "has_developer_token",
          "has_login_customer_id",
          "has_client_id",
          "has_client_secret",
          "has_refresh_token"
        ],
        "title": "GoogleAdsEnvSummary"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "HealthResponse": {
        "properties": {
          "status": {
            "type": "string",
            "title": "Status",
            "default": "ok"
          }
        },
        "type": "object",
        "title": "HealthResponse"
      },
      "LinkedInAccountRef": {
        "properties": {
          "id": {
            "type": "string",
            "title": "Id"
          },
          "name": {
            "type": "string",
            "title": "Name",
            "default": ""
          },
          "status": {
            "type": "string",
            "title": "Status",
            "default": ""
          },
          "currency": {
            "type": "string",
            "title": "Currency",
            "default": ""
          },
          "type": {
            "type": "string",
            "title": "Type",
            "default": ""
          }
        },
        "type": "object",
        "required": [
          "id"
        ],
        "title": "LinkedInAccountRef"
      },
      "LinkedInAccountsResponse": {
        "properties": {
          "count": {
            "type": "integer",
            "title": "Count"
          },
          "accounts": {
            "items": {
              "$ref": "#/components/schemas/LinkedInAccountRef"
            },
            "type": "array",
            "title": "Accounts"
          }
        },
        "type": "object",
        "required": [
          "count",
          "accounts"
        ],
        "title": "LinkedInAccountsResponse"
      },
      "LinkedInCampaignPerformance": {
        "properties": {
          "id": {
            "type": "string",
            "title": "Id"
          },
          "name": {
            "type": "string",
            "title": "Name",
