    "/linkedin/performance": {
      "get": {
        "summary": "LinkedIn Ads performance for one account",
        "operationId": "linkedin_performance_linkedin_performance_get",
        "security": [
          {
            "ApiKeyAuth": []
          }
        ],
        "parameters": [
          {
            "name": "account_id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Account Id"
            }
          },
          {
            "name": "date_range",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "default": "LAST_30_DAYS",
              "title": "Date Range"
