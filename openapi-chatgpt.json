{
  "openapi": "3.1.0",
  "info": {
    "title": "EOS Ads + GA4 Service",
    "version": "0.2.0",
    "description": "Google Ads, LinkedIn Ads, and GA4 BigQuery. Protected routes need header X-API-Key (Railway API_KEY). GET /health is public."
  },
  "servers": [
    {
      "url": "https://sagefrog-production.up.railway.app"
    }
  ],
